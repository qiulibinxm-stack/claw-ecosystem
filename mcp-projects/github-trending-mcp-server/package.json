{
  "name": "github-trending-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for GitHub Trending monitoring - 自动扫描GitHub热门项目，输出结构化学习简报",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "github-trending-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
