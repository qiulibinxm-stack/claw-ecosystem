    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "mcp",
    "github",
    "trending",
    "ai-agent",
    "learning"
  ],
  "author": "万能虾",
  "license": "MIT"
